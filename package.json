{
  "name": "portfolio-next-ts",
  "version": "0.2.0",
  "private": true,
  "browserslist": [
    "chrome >= 93",
    "edge >= 93",
    "firefox >= 92",
    "safari >= 15.4",
    "ios_saf >= 15.4"
  ],
  "scripts": {
    "dev": "node scripts/next-with-server-port.mjs dev",
    "build": "next build --webpack",
    "build:start": "npm run build && npm run start",
    "start": "node scripts/next-with-server-port.mjs start",
    "lint": "eslint",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "type-check": "tsc --noEmit",
    "remind:github-token": "node scripts/github-token-expiry-reminder.mjs"
  },
  "dependencies": {
    "maplibre-gl": "^5.21.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prettier": "3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}